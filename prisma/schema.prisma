generator client {
  provider = "prisma-client-js"
}


// --- ENUMS ---

enum Size {
  XS
  S
  M
  L
  XL
  XXL
  XXXL
}

enum Gender {
  men
  women
  kid
  unisex
}

enum Role {
  admin
  user
}

enum OrderStatus {
  pending
  processing
  paid
  shipped
  delivered
  cancelled
}

enum PaymentMethod {
  mercadopago
  transfer
}

// --- CONFIGURACIÓN SAAS / WHITE LABEL ---

model StoreConfig {
  id              String   @id @default(uuid())
  name            String   @default("Mi Tienda")
  logoUrl         String?
  primaryColor    String   @default("#3b82f6") 
  secondaryColor  String   @default("#1e293b")
  
  // Datos para Pago Manual (Transferencia)
  bankName        String?
  bankAccount     String?
  bankAccountType String? 
  bankOwnerName   String?
  bankCbu         String? 
  bankAlias       String?

  // Configuración de envíos y contacto
  shippingInfo    String?  @db.Text
  contactEmail    String?
  contactPhone    String?

  updatedAt       DateTime @updatedAt
}

// --- NÚCLEO DE PRODUCTOS ---

model Category {
  id      String    @id @default(uuid())
  name    String    @unique
  Product Product[]
}

model Product {
  id          String   @id @default(uuid())
  title       String
  description String
  inStock     Int
  price       Float    @default(0)
  slug        String   @unique
  tags        String[] @default([])
  
  // Opcionales para permitir productos que no sean ropa
  gender      Gender?  
  sizes       Size[]   @default([]) 

  // Relaciones
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  String

  ProductImage ProductImage[]
  OrderItem    OrderItem[]

  @@index([gender])
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String
  product   Product @relation(fields: [productId], references: [id])
  productId String
}

// --- USUARIOS Y DIRECCIONES ---

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String
  role          Role      @default(user)
  image         String?

  address       UserAddress?
  Order         Order[]
}

model Country {
  id           String         @id
  name         String
  UserAddress  UserAddress[]
  OrderAddress OrderAddress[]
}

model UserAddress {
  id         String  @id @default(uuid())
  firstName  String
  lastName   String
  address    String
  address2   String?
  postalCode String
  phone      String
  city       String

  country    Country @relation(fields: [countryId], references: [id])
  countryId  String
  user       User    @relation(fields: [userId], references: [id])
  userId     String  @unique
}

// --- SISTEMA DE ÓRDENES Y PAGOS ---

model Order {
  id            String    @id @default(uuid())
  subTotal      Float
  tax           Float
  total         Float
  itemsInOrder  Int
  
  // Control de Pago
  isPaid        Boolean       @default(false)
  paidAt        DateTime?
  paymentMethod PaymentMethod @default(mercadopago)
  status        OrderStatus   @default(pending)
  
  // Para Mercado Pago o Referencia de Transferencia
  transactionId  String?      
  paymentReceipt String?      // URL de la imagen del comprobante de transferencia

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relaciones
  user          User          @relation(fields: [userId], references: [id])
  userId        String
  OrderItem     OrderItem[]
  OrderAddress  OrderAddress?
}

model OrderItem {
  id        String  @id @default(uuid())
  quantity  Int
  price     Float
  size      Size?   // Opcional para productos genéricos

  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
}

model OrderAddress {
  id         String  @id @default(uuid())
  firstName  String
  lastName   String
  address    String
  address2   String?
  postalCode String
  city       String
  phone      String

  country    Country @relation(fields: [countryId], references: [id])
  countryId  String
  Order      Order   @relation(fields: [orderId], references: [id])
  orderId    String  @unique
}